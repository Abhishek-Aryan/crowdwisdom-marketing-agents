# CrowdWisdomTrading Marketing Agent — Environment Variables
# Copy this to .env and fill in your keys

# LLM Provider (pick one)
OPENROUTER_API_KEY=your_openrouter_key_here
# OR use NVIDIA: https://build.nvidia.com/

# Model to use (any OpenRouter model)
HERMES_MODEL=openrouter/auto

# Apify (free tier — get token at https://apify.com)
APIFY_TOKEN=your_apify_token_here

# Obsidian vault path
OBSIDIAN_VAULT_PATH=~/ObsidianVault/CrowdWisdomTrading

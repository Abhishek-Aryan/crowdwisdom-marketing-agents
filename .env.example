# ─── LLM Provider ────────────────────────────────────────────────────────────
# Option A: OpenRouter (https://openrouter.ai) — recommended
OPENROUTER_API_KEY=your_openrouter_key_here

# Option B: NVIDIA NIM (https://build.nvidia.com)
NVIDIA_API_KEY=your_nvidia_key_here

# Hermes model string — set to an OpenRouter or NVIDIA model
# OpenRouter examples: openai/gpt-4o, anthropic/claude-3-5-sonnet, meta-llama/llama-3.1-8b-instruct
# NVIDIA examples: nvidia/llama-3.1-nemotron-70b-instruct, meta/llama-3.1-405b-instruct
HERMES_MODEL=openai/gpt-4o

# Hermes home directory (where Hermes is installed)
HERMES_HOME=~/.hermes

# ─── Apify ───────────────────────────────────────────────────────────────────
# Get free token at https://apify.com — required for real ad scraping
APIFY_TOKEN=your_apify_token_here

# ─── Telegram Bot ────────────────────────────────────────────────────────────
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_USERS=your_telegram_user_id

# ─── Obsidian Vault ──────────────────────────────────────────────────────────
# Path to your Obsidian vault folder
OBSIDIAN_VAULT_PATH=~/ObsidianVault/CrowdWisdomTrading
